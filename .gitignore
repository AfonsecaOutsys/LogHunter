############################################################
# LogHunter - ignore local data + generated artifacts
############################################################

# --- Logs / data files you don't want shared ---
*.log
*.csv
*.xlsx
*.xls

# (optional) other common data dumps
*.txt
*.gz
*.zip
*.7z
*.json

# --- Runtime folders (your tool creates these) ---
output/
ALB/
IIS/
PlatformLogs/

# --- Build outputs ---
bin/
obj/
[Bb]uild/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa]ny[Cc][Pp][Uu]/
artifacts/
publish/

# --- IDE / user files ---
.vs/
.idea/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# --- OS junk ---
.DS_Store
Thumbs.db
